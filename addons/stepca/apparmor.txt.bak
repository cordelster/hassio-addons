#include <tunables/global>

profile stepca flags=(attach_disconnected,mediate_deleted) {
  # abstractions/base not available on HAOS — rules inlined explicitly

  # Base device access
  /dev/null rw,
  /dev/random r,
  /dev/urandom r,
  /dev/zero rw,
  /dev/tty rw,

  # Base proc/sys
  /proc/stat r,
  /proc/cpuinfo r,
  /proc/version r,
  /proc/meminfo r,
  /proc/loadavg r,
  /proc/ r,
  /proc/self/** r,
  /proc/*/cpuset r,
  /proc/*/mountinfo r,

  # Base network
  network inet stream,
  network inet dgram,
  network inet6 stream,
  network inet6 dgram,
  network unix stream,
  network unix dgram,

  # Capabilities — minimum required
  capability chown,           # chown -R step-ca:step-ca in cont-init and pki-restore
  capability dac_override,    # read/write step-ca owned files during init (running as root)
  capability fowner,          # chmod on secrets not owned by current process user
  capability setuid,          # s6-overlay user switching (step-ca service runs as step-ca)
  capability setgid,          # s6-overlay user switching
  capability net_bind_service, # step-ca binds port 443
  capability fsetid,           # cp -p preserves setgid bits on certificate files

  # Signals — s6-overlay service management
  # send: s6 signals its own children
  # receive: runc (unconfined) stops container; s6-supervise/svscan signal each other
  signal (send) set=(kill term int hup cont urg),
  signal (receive) set=(kill term int hup cont urg),

  # ===========================================================================
  # Shared libraries (r = open, m = mmap PROT_EXEC for loading)
  # ===========================================================================
  /lib/{,**} rm,
  /usr/lib/{,**} rm,
  /lib64/{,**} rm,

  # ===========================================================================
  # S6-Overlay and init system
  # ===========================================================================
  /init rix,
  /bin/** rix,
  /sbin/** rix,
  /usr/bin/** rix,
  /usr/sbin/** rix,
  /run/{s6,s6-rc*,service}/** ix,
  /package/** rix,
  /command/** ix,
  /etc/ w,                          # allows creating /etc/init.d/ and /etc/runlevels/ (s6-openrc-compat)
  /etc/init.d/{,**} rwix,           # s6-openrc-compat service shims
  /etc/runlevels/{,**} rw,          # s6-openrc-compat runlevel dirs and symlinks
  /etc/s6-overlay/{,**} rix,
  /etc/fix-attrs.d/{,**} r,
  /etc/services.d/{,**} rwix,
  /etc/cont-init.d/{,**} rwix,
  /etc/cont-finish.d/{,**} rwix,
  /run/{,**} rwk,
  /dev/tty rw,

  # ===========================================================================
  # Bashio
  # ===========================================================================
  /usr/lib/bashio/** ix,
  /tmp/{,**} rwk,

  # ===========================================================================
  # step-ca PKI
  # ===========================================================================
  /usr/bin/step-ca rix,
  /usr/bin/step rix,
  /data/{,**} rwk,

  # ===========================================================================
  # Addon scripts
  # ===========================================================================
  /usr/local/bin/** rix,
  /usr/local/lib/** rix,

  # ===========================================================================
  # Backup and restore
  # ===========================================================================
  /usr/bin/7z ix,
  /usr/bin/7za ix,
  /usr/bin/7zr ix,
  /ssl/{,**} rw,                   # HA ssl map: issued certs written by cert-renewal
  /config/{,**} rw,                # addon_config: restore bundles + backups/ subdir
  /share/stepca/backups/{,**} rw,  # alternate backup location

  # ===========================================================================
  # nginx + fcgiwrap
  # ===========================================================================
  /usr/sbin/nginx ix,
  /usr/sbin/fcgiwrap ix,
  /etc/nginx/{,**} rw,
  /var/log/{,**} rw,                # nginx logs + ACF log browser (needs dir listing)
  /var/lib/nginx/{,**} rw,
  /var/tmp/nginx/{,**} rw,
  /var/run/fcgiwrap.socket rw,

  # ===========================================================================
  # ACF (Alpine Configuration Framework)
  # ===========================================================================
  /usr/share/acf/www/cgi-bin/** rix,   # CGI scripts executed by fcgiwrap
  /usr/share/acf/www/{,**} r,          # static assets served by nginx
  /usr/share/acf/app/{,**} rw,         # Lua modules + stepca.conf written by cont-init
  /usr/share/acf/lib/{,**} r,          # ACF Lua libraries
  /usr/lib/lua/{,**} ix,               # Lua C extension modules (.so)
  /usr/share/lua/{,**} r,              # pure-Lua modules
  /usr/bin/lua* ix,
  /usr/bin/haserl ix,
  /data/webui/{,**} rw,
  /data/acf/{,**} rw,
  /etc/acf/{,**} rwk,                  # acf.conf, passwd symlink, skins; k for flock on passwd
  /run/ingress-token rw,               # ephemeral HA ingress session token

  # ===========================================================================
  # TLS and HTTP client (curl to supervisor API and step-ca health checks)
  # ===========================================================================
  /usr/bin/curl ix,
  /etc/ssl/{,**} r,
  /usr/share/ca-certificates/{,**} r,
  /usr/share/zoneinfo/{,**} r,

  # ===========================================================================
  # System access
  # ===========================================================================
  /proc/uptime r,
  /proc/sys/kernel/random/uuid r,
  /sys/kernel/mm/transparent_hugepage/hpage_pmd_size r,
  /etc/hosts r,
  /etc/resolv.conf r,
  /etc/nsswitch.conf r,
  /etc/hostname r,
  /etc/passwd r,
  /etc/group r,

  # Suppress known-safe denials that generate noise in audit log
  deny /proc/sys/kernel/random/boot_id r,
  deny /sys/devices/virtual/dmi/** r,
}
